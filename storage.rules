rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /homework/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        // Allow teachers and admins to read homework
        firestore.get(/databases/ai-studio-d0f6774b-9649-44a8-aa29-77447140a1e8/documents/users/$(request.auth.uid)).data.role in ['teacher', 'quran_teacher', 'sports_coach', 'school_admin', 'system_admin']
      );
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 10 * 1024 * 1024;
    }
    
    match /announcements/{schoolId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        firestore.get(/databases/ai-studio-d0f6774b-9649-44a8-aa29-77447140a1e8/documents/users/$(request.auth.uid)).data.role in ['school_admin', 'system_admin']
      );
    }

    match /authorized_person_files/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        firestore.get(/databases/ai-studio-d0f6774b-9649-44a8-aa29-77447140a1e8/documents/users/$(request.auth.uid)).data.role in ['school_admin', 'system_admin']
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
