{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for all roles (Admin, SchoolAdmin, Teacher, Parent, Child)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["system_admin", "school_admin", "teacher", "parent", "child"] },
        "schoolId": { "type": "string", "description": "Reference to School entity (if applicable)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "parentId": { "type": "string", "description": "UID of the parent (for children)" },
        "childIds": { "type": "array", "items": { "type": "string" }, "description": "List of child UIDs (for parents)" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "School": {
      "title": "School",
      "description": "Educational institution details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "adminId": { "type": "string", "description": "UID of the SchoolAdmin" }
      },
      "required": ["id", "name", "adminId"]
    },
    "Student": {
      "title": "Student",
      "description": "Student profile linked to a child user and parent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childUid": { "type": "string" },
        "parentUid": { "type": "string" },
        "schoolId": { "type": "string" },
        "teacherId": { "type": "string", "description": "Legacy field, use teacherIds" },
        "teacherIds": { "type": "array", "items": { "type": "string" }, "description": "List of teacher UIDs" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "location": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "lastUpdated": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "childUid", "parentUid", "schoolId"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "School-wide announcements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "title", "content"]
    },
    "SOSAlert": {
      "title": "SOS Alert",
      "description": "Emergency alerts triggered by children",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childUid": { "type": "string" },
        "parentUid": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "childUid", "parentUid", "status", "createdAt"]
    },
    "Incident": {
      "title": "Incident",
      "description": "Behavioral or safety incidents reported by teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["behavior", "safety", "other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "teacherId", "content", "type", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "teacherId", "status", "date"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Academic grades for students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "grade": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "teacherId", "grade", "createdAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Work assigned to students by teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "teacherRole": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "teacherId", "title", "description", "createdAt"]
    },
    "QuranProgress": {
      "title": "Quran Progress",
      "description": "Progress tracking for Quran memorization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "surah": { "type": "string" },
        "ayat": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["memorized", "reviewing", "improving"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "teacherId", "surah", "rating", "status", "createdAt"]
    },
    "SportsTraining": {
      "title": "Sports Training",
      "description": "Tracking for sports activities and performance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "exercise": { "type": "string" },
        "duration": { "type": "string" },
        "intensity": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "teacherId", "exercise", "duration", "intensity", "createdAt"]
    },
    "HomeworkSubmission": {
      "title": "Homework Submission",
      "description": "Homework submitted by students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "schoolId": { "type": "string" },
        "childUid": { "type": "string" },
        "teacherId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "studentName", "schoolId", "childUid", "title", "status", "submittedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback about other users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "toUid": { "type": "string" },
        "toName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fromUid", "toUid", "rating", "comment", "createdAt"]
    },
    "Call": {
      "title": "Call",
      "description": "Signaling for video calls",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "callerId": { "type": "string" },
        "callerName": { "type": "string" },
        "receiverId": { "type": "string" },
        "channel": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "ended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "callerId", "receiverId", "channel", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "School details"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records and real-time tracking"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "School announcements"
    },
    "/sos_alerts/{alertId}": {
      "schema": "SOSAlert",
      "description": "Active emergency alerts"
    },
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Reported incidents"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Academic grades"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Work assigned to students"
    },
    "/quran_progress/{progressId}": {
      "schema": "QuranProgress",
      "description": "Quran memorization progress"
    },
    "/sports_training/{trainingId}": {
      "schema": "SportsTraining",
      "description": "Sports training records"
    },
    "/homework_submissions/{submissionId}": {
      "schema": "HomeworkSubmission",
      "description": "Homework submissions"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback records"
    },
    "/calls/{callId}": {
      "schema": "Call",
      "description": "Call signaling records"
    }
  }
}
